# This is an example for local development
# Copy this to .env.local and fill in your values

# Database - Get from Neon.tech
DATABASE_URL="postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth - For local development
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# Cloudinary - Get from cloudinary.com dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your-secret-here"

# ============================================
# ADMIN CONFIGURATION
# ============================================
# This is the email for your uncle (the admin who can view all staff)
# He will use this email to login to the admin dashboard
# Default password after setup: admin123 (CHANGE THIS!)
ADMIN_EMAIL="admin@yourcompany.com"

# ============================================
# STAFF CREDENTIALS - READ THIS CAREFULLY!
# ============================================
#
# FORMAT: email:password,email:password,email:password
#         └────┬─────┘ └────┬─────┘ └────┬─────┘
#              │            │            │
#              │            │            └─ Third staff member
#              │            └────────────── Second staff member
#              └─────────────────────────── First staff member
#
# HOW IT WORKS:
# 1. YOU create an email and password for each staff member
# 2. Format: email:password (colon between them)
# 3. Separate multiple staff with commas (NO SPACES!)
# 4. Share the password privately with each staff member
#
# REAL EXAMPLE with 3 staff:
# Let's say you have:
#   - John Doe needs access → you create: john.doe@company.com with password JohnPass2024!
#   - Jane Smith needs access → you create: jane.smith@company.com with password JanePass2024!
#   - Bob Wilson needs access → you create: bob.wilson@company.com with password BobPass2024!
#
# You would write:
# STAFF_CREDENTIALS="john.doe@company.com:JohnPass2024!,jane.smith@company.com:JanePass2024!,bob.wilson@company.com:BobPass2024!"
#                    └─────────────────────────────┘ └──────────────────────────────┘ └─────────────────────────────┘
#                              John's login                  Jane's login                    Bob's login
#
# Then you tell each person privately:
#   - John: "Login with john.doe@company.com and password JohnPass2024!"
#   - Jane: "Login with jane.smith@company.com and password JanePass2024!"
#   - Bob: "Login with bob.wilson@company.com and password BobPass2024!"
#
STAFF_CREDENTIALS="john.doe@company.com:SecurePass123!,jane.smith@company.com:SecurePass456!,bob.wilson@company.com:SecurePass789!"
