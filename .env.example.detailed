# ============================================
# LOGISTICS STAFF PLATFORM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to Git (it's already in .gitignore)

# ============================================
# DATABASE (Neon PostgreSQL)
# ============================================
# Get this from: neon.tech → Your Project → Connection String
# Example: postgresql://user:pass@ep-cool-name-12345.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://username:password@your-neon-db-url/database?sslmode=require"

# ============================================
# NEXTAUTH (Authentication)
# ============================================
# For local development, use: http://localhost:3000
# For production (Vercel), use your actual URL: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Generate this secret with: openssl rand -base64 32
# Or use any random 32+ character string
# Example: Xk7mP9nQ2wR5tY8uI1oP3aS4dF6gH0jK9lM2nB5vC8xZ1aW4eR7tY0uI3oP6aS9d
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# ============================================
# CLOUDINARY (Image Storage)
# ============================================
# Get these from: cloudinary.com → Dashboard
# Cloud Name: Find in the dashboard URL or "Account Details"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# API Key: Found in "Account Details" section
CLOUDINARY_API_KEY="123456789012345"

# API Secret: Found in "Account Details" section (click to reveal)
CLOUDINARY_API_SECRET="your-api-secret-here"

# ============================================
# ADMIN CONFIGURATION
# ============================================
# This email will have ADMIN access (can view all staff)
# Typically your uncle's email address
# Default password after setup is: admin123 (CHANGE THIS!)
ADMIN_EMAIL="uncle@yourcompany.com"

# ============================================
# STAFF CREDENTIALS - READ THIS CAREFULLY!
# ============================================
#
# FORMAT EXPLANATION:
# -------------------
# Each staff member needs: email:password
#                          ↑     ↑
#                          |     └─ Password YOU create for them
#                          └─────── Their email address
#
# To add multiple staff, separate with commas (NO SPACES!)
#
# REAL WORLD EXAMPLE:
# -------------------
# Let's say you have 3 staff members:
# 1. John Doe - email: john.doe@company.com - you create password: JohnSecure2024!
# 2. Jane Smith - email: jane.smith@company.com - you create password: JaneSecure2024!
# 3. Bob Wilson - email: bob.wilson@company.com - you create password: BobSecure2024!
#
# You would write it as:
# STAFF_CREDENTIALS="john.doe@company.com:JohnSecure2024!,jane.smith@company.com:JaneSecure2024!,bob.wilson@company.com:BobSecure2024!"
#
# THEN, you would privately tell each person:
# - John: "Login with john.doe@company.com and password JohnSecure2024!"
# - Jane: "Login with jane.smith@company.com and password JaneSecure2024!"
# - Bob: "Login with bob.wilson@company.com and password BobSecure2024!"
#
# IMPORTANT RULES:
# ----------------
# ✅ DO: Use strong passwords
# ✅ DO: Use colons (:) between email and password
# ✅ DO: Use commas (,) between different staff members
# ✅ DO: Share passwords privately with each staff member
# ❌ DON'T: Add any spaces
# ❌ DON'T: Use special characters that might break the format
# ❌ DON'T: Share the entire .env file
#
# DEFAULT EXAMPLE (Replace with your actual staff):
STAFF_CREDENTIALS="staff1@company.com:password123,staff2@company.com:password456,staff3@company.com:password789"

# ============================================
# YOUR ACTUAL STAFF EXAMPLE
# ============================================
# Delete the line above and uncomment/edit the line below with YOUR staff:
# STAFF_CREDENTIALS="firststaff@yourcompany.com:FirstPassword123,secondstaff@yourcompany.com:SecondPassword456,thirdstaff@yourcompany.com:ThirdPassword789"
